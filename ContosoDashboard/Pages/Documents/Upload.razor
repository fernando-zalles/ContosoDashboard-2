@page "/documents/upload"
@using ContosoDashboard.Models
@using ContosoDashboard.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@attribute [Authorize]

@inject IDocumentService DocumentService
@inject IProjectService ProjectService
@inject IDocumentValidationService ValidationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Upload Document</PageTitle>

<DocumentLayout Title="Upload Document">
    <EditForm Model="uploadModel" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Title</label>
            <InputText class="form-control" @bind-Value="uploadModel.Title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control" @bind-Value="uploadModel.Description" Rows="3" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Category</label>
                <InputSelect class="form-select" @bind-Value="uploadModel.Category">
                    <option value="">Select category</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category">@category</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Project (optional)</label>
                <InputSelect class="form-select" @bind-Value="uploadModel.ProjectId">
                    <option value="">Personal / no project</option>
                    @foreach (var project in userProjects)
                    {
                        <option value="@project.ProjectId">@project.Name</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Tags (comma-separated)</label>
            <InputText class="form-control" @bind-Value="uploadModel.Tags" />
        </div>

        <div class="mb-3">
            <label class="form-label">File(s)</label>
            <InputFile OnChange="HandleFilesSelected" multiple="true" />
            @if (selectedFiles.Any())
            {
                <ul class="list-group mt-2">
                    @foreach (var file in selectedFiles)
                    {
                        <li class="list-group-item">@file.Name (@(file.Size / 1024) KB)</li>
                    }
                </ul>
            }
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert @statusClass" role="alert">@statusMessage</div>
        }

        <button class="btn btn-primary" type="submit" disabled="@isSubmitting">Upload</button>
    </EditForm>
</DocumentLayout>

@code {
    private UploadDocumentRequest uploadModel = new();
    private List<Project> userProjects = new();
    private IReadOnlyCollection<string> categories = Array.Empty<string>();
    private List<IBrowserFile> selectedFiles = new();
    private bool isSubmitting;
    private string? statusMessage;
    private string statusClass = "alert-info";
    private int currentUserId;
    private const long MaxFileSize = 25L * 1024 * 1024;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var parsedId))
            {
                currentUserId = parsedId;
            }
        }

        categories = ValidationService.AllowedCategories;

        if (currentUserId > 0)
        {
            userProjects = await ProjectService.GetUserProjectsAsync(currentUserId);
        }
    }

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles().ToList();
        statusMessage = null;
    }

    private async Task HandleValidSubmit()
    {
        if (currentUserId == 0)
        {
            statusMessage = "Unable to determine current user.";
            statusClass = "alert-danger";
            return;
        }

        if (!selectedFiles.Any())
        {
            statusMessage = "Please select at least one file to upload.";
            statusClass = "alert-warning";
            return;
        }

        isSubmitting = true;
        statusMessage = null;

        foreach (var file in selectedFiles)
        {
            if (file.Size > MaxFileSize)
            {
                statusMessage = $"File '@file.Name' exceeds the 25 MB limit.";
                statusClass = "alert-danger";
                isSubmitting = false;
                return;
            }

            var request = new UploadDocumentRequest
            {
                Title = uploadModel.Title,
                Description = uploadModel.Description,
                Category = uploadModel.Category,
                ProjectId = uploadModel.ProjectId,
                Tags = uploadModel.Tags,
                FileName = file.Name,
                ContentType = file.ContentType,
                FileSizeBytes = file.Size
            };

            await using var stream = file.OpenReadStream(MaxFileSize);
            request.File = stream;
            var uploadResult = await DocumentService.UploadDocumentAsync(currentUserId, request);

            if (!uploadResult.IsSuccess)
            {
                statusMessage = uploadResult.ErrorMessage;
                statusClass = "alert-danger";
                isSubmitting = false;
                return;
            }
        }

        statusMessage = "Upload completed successfully.";
        statusClass = "alert-success";
        selectedFiles.Clear();
        uploadModel = new UploadDocumentRequest();
        isSubmitting = false;
    }
}
